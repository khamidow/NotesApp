<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:clipToOutline="true"
    android:layout_height="match_parent"
    android:background="@drawable/note_bcg">

    <TextView
        android:id="@+id/info_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="19dp"
        android:fontFamily="@font/baloo_regular"
        android:text="Do you want to log out?"
        android:textColor="@color/black"
        android:textSize="21sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/yes_btn"
        android:layout_width="0dp"
        android:layout_height="47dp"
        android:layout_margin="19dp"
        android:background="@drawable/ed_btn"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/baloo_regular"
        android:foreground="?android:selectableItemBackgroundBorderless"
        android:text="Yes"
        android:textColor="@color/secondary_white"
        android:textSize="17sp"
        android:elevation="9dp"
        android:textStyle="bold"
        app:layout_constraintLeft_toRightOf="@id/no_btn"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/info_tv" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/no_btn"
        android:layout_width="0dp"
        android:layout_height="47dp"
        android:layout_margin="19dp"
        android:background="@drawable/ed_btn"
        android:clickable="true"
        android:focusable="true"
        android:fontFamily="@font/baloo_regular"
        android:foreground="?android:selectableItemBackgroundBorderless"
        android:text="No"
        android:textColor="@color/secondary_white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="9dp"
        app:layout_constraintRight_toLeftOf="@id/yes_btn"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/info_tv" />
</androidx.constraintlayout.widget.ConstraintLayout>