<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <TextView
        android:id="@+id/top_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="9dp"
        android:layout_marginTop="33dp"
        android:fontFamily="@font/baloo_bold"
        android:text="Notes"
        android:textColor="@color/black"
        android:textSize="31sp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/log_out_btn"
        android:layout_width="31dp"
        android:layout_height="31dp"
        android:layout_marginRight="9dp"
        android:background="?android:selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="1dp"
        android:src="@drawable/log_out"
        app:layout_constraintBottom_toBottomOf="@id/top_title"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@id/top_title" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/note_rv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/secondary_white"
        android:paddingTop="9dp"
        app:layoutManager="androidx.recyclerview.widget.StaggeredGridLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/top_title"
        app:spanCount="2"
        tools:listitem="@layout/item_note" />

    <ImageView
        android:id="@+id/placeholder_img"
        android:layout_width="130dp"
        android:layout_height="150dp"
        android:alpha="0.3"
        android:src="@drawable/note_placeholder"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/placeholder_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.4"
        android:fontFamily="@font/baloo_bold"
        android:text="No notes yet"
        android:textColor="@color/secondary_text"
        android:textSize="17sp"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/placeholder_img" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/add_btn"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_margin="13dp"
        android:background="@drawable/ed_btn"
        android:clickable="true"
        android:clipToOutline="true"
        android:focusable="true"
        android:fontFamily="@font/baloo_bold"
        android:foreground="?android:selectableItemBackgroundBorderless"
        android:paddingTop="3dp"
        android:text="+"
        android:textColor="@color/secondary_white"
        android:textSize="29sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/loading_pb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/main_color"
        app:layout_constraintTop_toTopOf="@id/note_rv"
        app:layout_constraintBottom_toTopOf="@id/note_rv"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:trackColor="@color/secondary_text" />

</androidx.constraintlayout.widget.ConstraintLayout>