<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/secondary_white">

    <TextView
        android:id="@+id/tv_sign_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="99dp"
        android:fontFamily="@font/baloo_bold"
        android:text="Sign In"
        android:textColor="@color/black"
        android:textSize="35sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/ed_email"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:fontFamily="@font/baloo_regular"
        android:text="Email Address"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/ed_email"
        app:layout_constraintLeft_toLeftOf="@id/ed_email" />

    <TextView
        android:id="@+id/email_error_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:fontFamily="@font/baloo_regular"
        android:textColor="@color/error_color"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/ed_email"
        app:layout_constraintRight_toRightOf="@id/ed_email" />

    <EditText
        android:id="@+id/ed_email"
        android:layout_width="match_parent"
        android:layout_height="47dp"
        android:layout_marginHorizontal="19dp"
        android:layout_marginBottom="39dp"
        android:background="@drawable/ed_bcg"
        android:elevation="9dp"
        android:fontFamily="@font/baloo_regular"
        android:inputType="text"
        android:maxLength="32"
        android:maxLines="1"
        android:paddingHorizontal="9dp"
        android:textColor="@color/secondary_text"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/ed_password"
        app:layout_constraintTop_toBottomOf="@id/tv_sign_in" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:fontFamily="@font/baloo_regular"
        android:text="Password"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/ed_password"
        app:layout_constraintLeft_toLeftOf="@id/ed_password" />

    <TextView
        android:id="@+id/password_error_tv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="1dp"
        android:fontFamily="@font/baloo_regular"
        android:textColor="@color/error_color"
        android:textStyle="bold"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@id/ed_password"
        app:layout_constraintRight_toRightOf="@id/ed_password" />

    <EditText
        android:id="@+id/ed_password"
        android:layout_width="match_parent"
        android:layout_height="47dp"
        android:layout_marginHorizontal="19dp"
        android:layout_marginBottom="59dp"
        android:background="@drawable/ed_bcg"
        android:elevation="9dp"
        android:fontFamily="@font/baloo_regular"
        android:inputType="textPassword"
        android:maxLength="16"
        android:maxLines="1"
        android:paddingHorizontal="9dp"
        android:textColor="@color/secondary_text"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/sign_in_btn"
        app:layout_constraintTop_toBottomOf="@id/ed_email" />

    <CheckBox
        android:id="@+id/show_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="@color/black"
        app:layout_constraintLeft_toLeftOf="@id/ed_password"
        app:layout_constraintTop_toBottomOf="@id/ed_password" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/baloo_regular"
        android:text="Show Password"
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/show_password"
        app:layout_constraintLeft_toRightOf="@id/show_password"
        app:layout_constraintTop_toTopOf="@id/show_password" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/sign_in_btn"
        android:layout_width="match_parent"
        android:layout_height="47dp"
        android:layout_marginHorizontal="19dp"
        android:background="@drawable/ed_btn"
        android:clickable="true"
        android:clipToOutline="true"
        android:focusable="true"
        android:fontFamily="@font/baloo_regular"
        android:foreground="?android:selectableItemBackgroundBorderless"
        android:text="Sign In"
        android:textAllCaps="false"
        android:textColor="@color/secondary_white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ed_password" />

    <TextView
        android:id="@+id/tv_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:fontFamily="@font/baloo_regular"
        android:text="Don't you hava an account? "
        android:textColor="@color/black"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/tv_sign_up"
        app:layout_constraintTop_toBottomOf="@id/sign_in_btn" />

    <TextView
        android:id="@+id/tv_sign_up"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:fontFamily="@font/baloo_regular"
        android:text="Sign Up"
        android:textColor="@color/main_color"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintLeft_toRightOf="@id/tv_bottom"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sign_in_btn" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/google_btn"
        android:layout_width="match_parent"
        android:layout_height="47dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="9dp"
        android:clipToOutline="true"
        android:foreground="?android:selectableItemBackgroundBorderless"
        android:layout_marginHorizontal="19dp"
        android:layout_marginBottom="19dp"
        android:background="@drawable/ed_bcg"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginLeft="9dp"
            android:src="@drawable/google_logo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/baloo_regular"
            android:text="Continue with Google"
            android:textColor="@color/black"
            android:textSize="19sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/loading_pb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/main_color"
        app:layout_constraintTop_toTopOf="parent"
        app:trackColor="@color/secondary_text" />
</androidx.constraintlayout.widget.ConstraintLayout>